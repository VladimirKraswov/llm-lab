{
  "name": "forge-ml-execution-fabric",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "web:dev": "npm --prefix web run dev -- --host 0.0.0.0",
    "web:build": "npm --prefix web run build",
    "dev:all": "concurrently -n api,web -c green,blue \"npm run dev\" \"npm run web:dev\"",
    "start:all": "npm run web:build && npm run start"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "multer": "^2.1.1",
    "sqlite3": "^6.0.1",
    "systeminformation": "^5.31.4"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
