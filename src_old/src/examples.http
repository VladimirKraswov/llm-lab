### Health
GET http://localhost:8787/health

### Login
POST http://localhost:8787/api/v1/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123456"
}

### List runtime profiles
GET http://localhost:8787/api/v1/runtime-profiles
Authorization: Bearer {{jwt}}

### Create trainer job
POST http://localhost:8787/api/v1/trainer/jobs
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "runtimeProfileId": "{{runtimeProfileId}}",
  "jobId": "job_qwen_7b_remote_001",
  "name": "qwen-7b-remote-train",
  "config": {
    "job_name": "qwen-7b-remote-train",
    "mode": "remote",
    "model": {
      "source": "local",
      "local_path": "/app",
      "trust_remote_code": false,
      "load_in_4bit": true,
      "dtype": "bfloat16",
      "max_seq_length": 1024
    },
    "dataset": {
      "source": "url",
      "train_url": "https://example.com/api/datasets/train.json",
      "val_url": "https://example.com/api/datasets/val.json",
      "format": "instruction_output",
      "input_field": "input",
      "output_field": "output"
    },
    "training": {
      "method": "qlora",
      "max_seq_length": 1024,
      "per_device_train_batch_size": 1,
      "gradient_accumulation_steps": 1,
      "num_train_epochs": 1,
      "learning_rate": 0.0001,
      "warmup_ratio": 0.03,
      "logging_steps": 1,
      "save_steps": 10,
      "eval_steps": 10,
      "bf16": true,
      "packing": false,
      "save_total_limit": 1,
      "optim": "adamw_8bit"
    },
    "lora": {
      "r": 8,
      "lora_alpha": 16,
      "lora_dropout": 0.0,
      "bias": "none",
      "use_gradient_checkpointing": "unsloth",
      "random_state": 3407,
      "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj"]
    },
    "outputs": {
      "base_dir": "/output/job_qwen_7b_remote_001"
    },
    "evaluation": {
      "enabled": true,
      "target": "auto",
      "max_samples": 10,
      "max_new_tokens": 64,
      "temperature": 0.0,
      "do_sample": false,
      "dataset": {
        "source": "url",
        "url": "https://example.com/api/datasets/eval.jsonl",
        "format": "jsonl",
        "question_field": "question",
        "answer_field": "candidate_answer",
        "score_field": "reference_score",
        "max_score_field": "max_score",
        "tags_field": "hash_tags"
      }
    },
    "upload": {
      "enabled": true,
      "target": "url"
    },
    "huggingface": {
      "enabled": false,
      "push_lora": false,
      "push_merged": false
    }
  },
  "executor": {
    "image": "igortet/itk-ai-trainer-service:qwen-7b",
    "gpus": "all",
    "shmSize": "16g"
  }
}

### Build launch spec
GET http://localhost:8787/api/v1/trainer/jobs/job_qwen_7b_remote_001/launch-spec
Authorization: Bearer {{jwt}}

### Launch trainer job and inherit HF_TOKEN from backend env
POST http://localhost:8787/api/v1/trainer/jobs/job_qwen_7b_remote_001/launch
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "inheritEnv": ["HF_TOKEN"]
}

### Job details
GET http://localhost:8787/api/v1/jobs/job_qwen_7b_remote_001
Authorization: Bearer {{jwt}}

### Job logs
GET http://localhost:8787/api/v1/jobs/job_qwen_7b_remote_001/logs
Authorization: Bearer {{jwt}}

### Job artifacts
GET http://localhost:8787/api/v1/jobs/job_qwen_7b_remote_001/artifacts
Authorization: Bearer {{jwt}}
