{
  "job_name": "qwen25-7b-local-test",
  "mode": "local",
  "model": {
    "source": "local",
    "local_path": "/models/base/qwen-2.5-7b-instruct-model_bea0c1db337f",
    "trust_remote_code": false
  },
  "dataset": {
    "source": "local",
    "train_path": "/workspace/datasets/train.json",
    "val_path": "/workspace/datasets/val.json",
    "format": "instruction_output",
    "input_field": "input",
    "output_field": "output"
  },
  "training": {
    "method": "qlora",
    "max_seq_length": 4096,
    "per_device_train_batch_size": 1,
    "gradient_accumulation_steps": 8,
    "num_train_epochs": 1,
    "learning_rate": 0.0001,
    "warmup_ratio": 0.03,
    "logging_steps": 1,
    "save_steps": 50,
    "eval_steps": 50,
    "bf16": true,
    "packing": true
  },
  "lora": {
    "r": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.0,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ]
  },
  "outputs": {
    "base_dir": "/workspace/artifacts",
    "logs_dir": "/workspace/artifacts/logs",
    "lora_dir": "/workspace/artifacts/lora",
    "checkpoints_dir": "/workspace/artifacts/checkpoints",
    "metrics_dir": "/workspace/artifacts/metrics",
    "merged_dir": "/workspace/artifacts/merged",
    "quantized_dir": "/workspace/artifacts/quantized"
  },
  "postprocess": {
    "merge_lora": true,
    "save_merged_16bit": true,
    "run_awq_quantization": false
  },
  "upload": {
    "enabled": false,
    "target": "local"
  }
}