    "random_state": 3407,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ]
  },
  "outputs": {
    "base_dir": "/output/qwen25-05b-demo-local"
